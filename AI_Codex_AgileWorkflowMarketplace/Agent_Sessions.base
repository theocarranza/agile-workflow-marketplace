filters:
  and:
    - file.inFolder("Agent_Sessions")
    - 'file.ext == "md"'
    - 'file.name != "README"'

formulas:
  age_days: '(now() - file.ctime).days'
  has_meta: 'if(type, "✅", "⚠️ no frontmatter")'

properties:
  date:
    displayName: Date
  status:
    displayName: Status
  formula.age_days:
    displayName: "Age (d)"
  formula.has_meta:
    displayName: Meta

views:
  - type: table
    name: Sessions
    order:
      - file.name
      - date
      - status
      - formula.age_days

  - type: table
    name: Open Sessions
    filters:
      and:
        - status == "open"
    order:
      - file.link
      - date
      - status
      - file.mtime

  - type: table
    name: All Sessions
    order:
      - file.link
      - date
      - status
      - file.mtime

  - type: table
    name: Needs metadata
    filters:
      not:
        - type
    order:
      - file.name
      - file.mtime
